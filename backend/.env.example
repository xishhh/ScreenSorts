# ScreenSorts Backend Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_TITLE=ScreenSorts API
APP_VERSION=0.1.0

# Project root override (set to /app in Docker — not needed for native runs)
# PROJECT_ROOT=/app

# CORS — comma-separated origins allowed
CORS_ORIGINS=http://localhost:3000

# Repository paths (relative to project root)
REPO_DEMO_DIR=data/demo
REPO_USER_DIR=data/user
REPO_METADATA_DIR=data/metadata
REPO_DATASETS_DIR=data/datasets

# Demo Corpus Builder
DEMO_SAMPLE_SIZE=100
DEMO_RANDOM_SEED=42

# OCR
OCR_RESULTS_DIR=data/ocr_results
OCR_BATCH_SIZE=10

# Embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDINGS_DIR=data/embeddings

# ChromaDB Vector Store
CHROMA_PERSIST_DIR=vector_store
CHROMA_COLLECTION_NAME=screensorts
CHROMA_BATCH_SIZE=50

# Groq API (required for AI explanations)
# Get your API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=300
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=2
GROQ_CACHE_DIR=data/explanation_cache
