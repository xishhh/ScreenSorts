# ScreenSorts Backend Configuration

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_TITLE=ScreenSorts API
APP_VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:3000

# Repository
